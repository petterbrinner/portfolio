---
import ThemeToggle from "./ThemeToggle.svelte";

interface Props {
  title?: string;
}

const { title = "Petter Johansson" } = Astro.props;

const navItems = [
  { href: "/", label: "Start" },
  { href: "/profil", label: "Profil" },
  { href: "/case", label: "Case" },
];

const jokes = [
  "Jag förvarar kläderna i garaget; det är en åk-in closet.",
  "Garnityren ger mig onda aningar; det är persillvilja",
  "Jag läste medeltida poesi i min ungdom; blir ofta noskaldisk.",
  "Ambivalenta fotografers förening: ”Skärpa är ett av våra många fokus.”",
  // 'Servern går på ångkraft; den är veveved-driven.',
  "Ljumma musikgenrer #1: Ganska-rap.",
  "Ljumma musikgenrer #2: Tvekno.",
  "Ljumma musikgenrer #3: Okej-pop.",
  "Ljumma musikgenrer #4: Si-och-soul.",
  "Ljumma musikgenrer #5: Tråk'n roll.",
  "Ljumma musikgenrer #6: Jorådisco.",
];
---

<header class="contents">
  <div
    id="name"
    class="grid col-[header-start/header-end] row-[header-start/header-end] p-2 px-3"
  >
    <a
      href="/"
      class="font-serif text-3xl font-semibold whitespace-nowrap styled-anchor"
      >{title}</a
    >
    <p class="mt-2 text-sm text-balance">
      Full-stack webbutvecklare och -designer.
    </p>
    <a
      href="mailto:petter.johansson@icloud.com"
      class="mt-2 text-sm styled-anchor"
    >
      petter.johansson@icloud.com
    </a>
    <a href="tel:0707494047" class="mt-0.5 text-sm styled-anchor">
      070-749 40 47
    </a>
  </div>
  <ul
    class="p-2 px-3 justify-end flex flex-col gap-x-2 text-right col-[nav-start/nav-end] row-[nav-start/nav-end]"
  >
    {
      navItems.map((item) => (
        <li>
          <a
            href={item.href}
            class="font-serif text-lg font-medium md:text-2xl styled-anchor"
          >
            {item.label}
          </a>
        </li>
      ))
    }
  </ul>
  <div
    id="theme-toggle-container"
    class="p-2 px-3 flex items-center gap-x-2 font-serif justify-self-end place-self-end col-[mode-start/mode-end] row-[mode-start/mode-end]"
  >
    <span class="theme-toggle-label">Tema:</span>
    <ThemeToggle client:load />
  </div>
</header>

<footer
  class="flex gap-[0.5em] p-2 px-3 font-serif italic text-sm col-[footer-start/footer-end] row-[footer-start/footer-end] self-end"
>
  <span>></span>
  <span id="joke" class="text-balance"></span>
</footer>

<script define:vars={{ jokes }}>
  const name = document.getElementById("name");
  if (name) {
    const setNameHeight = () => {
      document.documentElement.style.setProperty(
        "--header-height",
        `${name.offsetHeight + 8}px`,
      );
    };
    setNameHeight();
    new ResizeObserver(setNameHeight).observe(name);
  }

  const joke = document.getElementById("joke");
  if (joke) {
    joke.textContent = jokes[Math.floor(Math.random() * jokes.length)];
  }
</script>
