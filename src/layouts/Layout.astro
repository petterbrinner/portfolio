---
import { Font } from 'astro:assets';
import Head from '../components/Head.astro';
import { pageTitle, SITE } from '../lib/seo';
import '../styles/global.css';

interface Props {
	title?: string;
	description?: string;
	image?: string;
	imageAlt?: string;
	type?: 'website' | 'article';
	noindex?: boolean;
	schema?: object | object[];
}

const {
	title = SITE.name,
	description = SITE.defaultDescription,
	image,
	imageAlt,
	type = 'website',
	noindex = false,
	schema,
} = Astro.props;

const resolvedTitle = pageTitle(title);
---

<!doctype html>
<html lang="sv">
	<head>
		<script is:inline>
			document.documentElement.classList.toggle(
				'dark',
				localStorage.theme === 'dark' ||
					(!('theme' in localStorage) &&
						window.matchMedia('(prefers-color-scheme: dark)').matches),
			);
		</script>
		<Font cssVariable="--font-instrument-sans" preload />
		<Font cssVariable="--font-instrument-serif" />
		<Font cssVariable="--font-datatype" />
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<Head
			title={resolvedTitle}
			description={description}
			image={image}
			imageAlt={imageAlt}
			type={type}
			noindex={noindex}
			schema={schema}
		/>
		<title>{resolvedTitle}</title>
	</head>
	<body class="grid w-screen h-screen
    content-start items-start
    grid-cols-[[name-start_aside-start_main-start_footer-start]_auto_[name-end_nav-start]_1fr_[nav-end_mode-start]_auto_[mode-end_aside-end_main-end_footer-end]]
    grid-rows-[[name-start_nav-start_mode-start]_auto_[name-end_nav-end_mode-end_aside-start]_auto_[aside-end_main-start]_1fr_[main-end_footer-start]_auto_[footer-end]]
    md:grid-cols-[[name-start_aside-start_footer-start]_280px_[name-end_aside-end_footer-end]_auto_[aside-end]_1rem_[main-start]_auto_[main-end_nav-start_mode-start]_1fr_[nav-end_mode-end]]
    md:grid-rows-[[name-start_nav-start_main-start]_auto_[name-end_nav-end_aside-start]_1fr_[mode-start_footer-start]_auto_[aside-end_main-end_mode-end_footer-end]]
    xl:grid-cols-[[name-start_footer-start]_280px_[name-end_footer-end_aside-start]_280px_[aside-end]_1rem_[main-start]_auto_[main-end_nav-start_mode-start]_1fr_[nav-end_mode-end]]
    xl:grid-rows-[[name-start_nav-start_main-start]_auto_[name-end_nav-end_aside-start]_1fr_[mode-start_footer-start]_auto_[aside-end_main-end_mode-end_footer-end]]">
		<slot />
	</body>
</html>
